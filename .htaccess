# =============================================================
# Beget — potolok-i-tochka.ru
# =============================================================

DirectoryIndex index.html index.htm
ErrorDocument 404 /404.html
Options -Indexes
AddDefaultCharset UTF-8
AddCharset UTF-8 .html .css .js .xml .json .txt .svg

<IfModule mod_mime.c>
  AddType image/svg+xml .svg
  AddType image/webp .webp
  AddType application/manifest+json .webmanifest
  AddType font/woff2 .woff2
  AddType font/woff .woff
</IfModule>

# =============================================================
# REWRITE — короткие URL без .html + 301 редиректы со старых
# =============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # --- HTTPS-redirect через X-Forwarded-Proto (Beget nginx-прокси) ---
  RewriteCond %{HTTP:X-Forwarded-Proto} !https
  RewriteCond %{HTTP_HOST} ^(www\.)?potolok-i-tochka\.ru$ [NC]
  RewriteRule ^ https://potolok-i-tochka.ru%{REQUEST_URI} [L,R=301]

  # --- www → без www ---
  RewriteCond %{HTTP_HOST} ^www\.potolok-i-tochka\.ru$ [NC]
  RewriteRule ^ https://potolok-i-tochka.ru%{REQUEST_URI} [L,R=301]

  # --- Старый поддомен → новый домен ---
  RewriteCond %{HTTP_HOST} ^verbov1j\.beget\.tech$ [NC]
  RewriteRule ^ https://potolok-i-tochka.ru%{REQUEST_URI} [L,R=301]

  # --- /index.html → / ---
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ https://potolok-i-tochka.ru/ [L,R=301]

  # --- 301 редиректы со старых .html на короткие URL ---
  # %{THE_REQUEST} проверяет ОРИГИНАЛЬНЫЙ запрос клиента, не rewritten —
  # иначе будет бесконечный цикл с внутренним rewrite ниже
  RewriteCond %{THE_REQUEST} \s/+tseny\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/tseny [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+raschet-po-foto\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/raschet [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+novostroyka\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/novostroyka [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+zamena-potolka\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/zamena [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+sliv-vody\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/sliv-vody [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+matovye-potolki\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/matovye [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+satinovye-potolki\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/satinovye [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+tkanevye-potolki\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/tkanevye [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+tenevye-potolki\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/tenevye [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+premium-potolki\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/premium [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+potolki-s-podsvetkoy\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/podsvetka [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+skrytyy-karniz\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/karniz [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+potolok-v-spalnu\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/spalnya [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+potolok-na-kuhnu\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/kuhnya [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+potolok-v-gostinuyu\.html[\s?] [NC]
  RewriteRule ^ https://potolok-i-tochka.ru/gostinaya [R=301,L]

  # --- Слэш на конце → без слэша ---
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{THE_REQUEST} \s/+([^\s?]+)/[\s?]
  RewriteRule ^(.+)/$ https://potolok-i-tochka.ru/$1 [R=301,L]

  # --- Короткий URL → реальный файл (внутренний rewrite, без редиректа) ---
  RewriteRule ^tseny$       tseny.html               [L]
  RewriteRule ^raschet$     raschet-po-foto.html     [L]
  RewriteRule ^novostroyka$ novostroyka.html         [L]
  RewriteRule ^zamena$      zamena-potolka.html      [L]
  RewriteRule ^sliv-vody$   sliv-vody.html           [L]
  RewriteRule ^matovye$     matovye-potolki.html     [L]
  RewriteRule ^satinovye$   satinovye-potolki.html   [L]
  RewriteRule ^tkanevye$    tkanevye-potolki.html    [L]
  RewriteRule ^tenevye$     tenevye-potolki.html     [L]
  RewriteRule ^premium$     premium-potolki.html     [L]
  RewriteRule ^podsvetka$   potolki-s-podsvetkoy.html [L]
  RewriteRule ^karniz$      skrytyy-karniz.html      [L]
  RewriteRule ^spalnya$     potolok-v-spalnu.html    [L]
  RewriteRule ^kuhnya$      potolok-na-kuhnu.html    [L]
  RewriteRule ^gostinaya$   potolok-v-gostinuyu.html [L]
</IfModule>

# =============================================================
# Запрет доступа к служебным файлам
# =============================================================
<FilesMatch "^\.(htaccess|htpasswd|git|env|DS_Store)">
  Require all denied
</FilesMatch>

<FilesMatch "\.(md|pl|sh|log|bak|sql|gitignore|gitattributes)$">
  Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule "(^|/)\.git" - [F,L]
  RewriteRule "(^|/)\.claude" - [F,L]
  RewriteRule "(^|/)node_modules" - [F,L]
</IfModule>

# =============================================================
# Кэш браузера
# =============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 hour"
  ExpiresByType text/html                 "access plus 1 hour"
  ExpiresByType text/css                  "access plus 7 days"
  ExpiresByType application/javascript    "access plus 7 days"
  ExpiresByType image/png                 "access plus 30 days"
  ExpiresByType image/jpeg                "access plus 30 days"
  ExpiresByType image/webp                "access plus 30 days"
  ExpiresByType image/svg+xml             "access plus 30 days"
  ExpiresByType image/x-icon              "access plus 365 days"
  ExpiresByType font/woff                 "access plus 365 days"
  ExpiresByType font/woff2                "access plus 365 days"
  ExpiresByType application/manifest+json "access plus 7 days"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|svg|png|jpg|jpeg|webp|ico|woff2?)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|xml|json|webmanifest)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# =============================================================
# Gzip-сжатие
# =============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/xml text/plain text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml application/xhtml+xml application/manifest+json
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2 font/woff
</IfModule>

# =============================================================
# Security headers
# =============================================================
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-XSS-Protection "1; mode=block"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"
  Header set Cross-Origin-Opener-Policy "same-origin-allow-popups"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header unset X-Powered-By
  Header unset Server
  Header unset ETag
</IfModule>
FileETag None
