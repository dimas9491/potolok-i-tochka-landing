# =============================================================
# Beget — potolok-i-tochka.ru
# Когда SSL выпустится — раскомментируй HTTP→HTTPS блок и HSTS
# =============================================================

# Главная — index.html (а не дефолтный index.php от хостинга)
DirectoryIndex index.html index.htm

# Кастомная 404
ErrorDocument 404 /404.html

# Запрет листинга директорий
Options -Indexes

# UTF-8 по умолчанию для текстовых файлов
AddDefaultCharset UTF-8
AddCharset UTF-8 .html .css .js .xml .json .txt .svg

# Корректные MIME для современных файлов
<IfModule mod_mime.c>
  AddType image/svg+xml .svg
  AddType image/webp .webp
  AddType application/manifest+json .webmanifest
  AddType font/woff2 .woff2
  AddType font/woff .woff
</IfModule>

# =============================================================
# Редиректы
# =============================================================
<IfModule mod_rewrite.c>
  RewriteEngine On

  # 1) HTTP → HTTPS — РАСКОММЕНТИРОВАТЬ ПОСЛЕ ВЫПУСКА SSL
  # RewriteCond %{HTTPS} !=on
  # RewriteCond %{HTTP_HOST} ^(www\.)?potolok-i-tochka\.ru$ [NC]
  # RewriteRule ^ https://potolok-i-tochka.ru%{REQUEST_URI} [L,R=301]

  # 2) www → без www
  RewriteCond %{HTTP_HOST} ^www\.potolok-i-tochka\.ru$ [NC]
  RewriteRule ^ http://potolok-i-tochka.ru%{REQUEST_URI} [L,R=301]

  # 3) verbov1j.beget.tech → potolok-i-tochka.ru
  RewriteCond %{HTTP_HOST} ^verbov1j\.beget\.tech$ [NC]
  RewriteRule ^ http://potolok-i-tochka.ru%{REQUEST_URI} [L,R=301]

  # 4) /index.html → / (убираем дубль главной для SEO)
  RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
  RewriteRule ^index\.html$ / [L,R=301]
</IfModule>

# =============================================================
# Запрет доступа к служебным файлам
# =============================================================
<FilesMatch "^\.(htaccess|htpasswd|git|env|DS_Store)">
  Require all denied
</FilesMatch>

<FilesMatch "\.(md|pl|sh|log|bak|sql|gitignore|gitattributes)$">
  Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule "(^|/)\.git" - [F,L]
  RewriteRule "(^|/)\.claude" - [F,L]
  RewriteRule "(^|/)node_modules" - [F,L]
</IfModule>

# =============================================================
# Кэш браузера
# =============================================================
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresDefault                          "access plus 1 hour"
  ExpiresByType text/html                 "access plus 1 hour"
  ExpiresByType text/css                  "access plus 7 days"
  ExpiresByType application/javascript    "access plus 7 days"
  ExpiresByType image/png                 "access plus 30 days"
  ExpiresByType image/jpeg                "access plus 30 days"
  ExpiresByType image/webp                "access plus 30 days"
  ExpiresByType image/svg+xml             "access plus 30 days"
  ExpiresByType image/x-icon              "access plus 365 days"
  ExpiresByType font/woff                 "access plus 365 days"
  ExpiresByType font/woff2                "access plus 365 days"
  ExpiresByType application/manifest+json "access plus 7 days"
</IfModule>

# Cache-Control как страховка
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|svg|png|jpg|jpeg|webp|ico|woff2?)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  <FilesMatch "\.(html|xml|json|webmanifest)$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# =============================================================
# Gzip-сжатие
# =============================================================
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/xml text/plain text/javascript
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml application/xhtml+xml application/manifest+json
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2 font/woff
</IfModule>

# =============================================================
# Security headers
# =============================================================
<IfModule mod_headers.c>
  # Защита от MIME-sniffing
  Header set X-Content-Type-Options "nosniff"

  # Защита от clickjacking (но разрешаем фреймы с того же домена)
  Header set X-Frame-Options "SAMEORIGIN"

  # XSS защита для старых браузеров
  Header set X-XSS-Protection "1; mode=block"

  # Referrer-Policy: отправляем referer только на свой домен полностью, иначе только origin
  Header set Referrer-Policy "strict-origin-when-cross-origin"

  # Permissions-Policy — выключаем доступ к камере/микрофону/геолокации
  Header set Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=()"

  # Cross-Origin policies
  Header set Cross-Origin-Opener-Policy "same-origin-allow-popups"

  # HSTS — РАСКОММЕНТИРОВАТЬ ПОСЛЕ ВЫПУСКА SSL И ПРОВЕРКИ HTTPS
  # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Удаляем серверные fingerprint-заголовки
  Header unset X-Powered-By
  Header unset Server
</IfModule>

# =============================================================
# Отключаем ETag (используем Last-Modified)
# =============================================================
<IfModule mod_headers.c>
  Header unset ETag
</IfModule>
FileETag None
